def test_update_insumo(session, created):
    iid = created["insumos"][0]
    payload = {
        "nome": "TEST_Tomate", "unidade_compra": "kg", "unidade_uso": "g",
        "fator_conversao": 1000.0, "peso_bruto": 1.0, "peso_liquido": 0.8,
        "preco": 20.0,  # double price
        "estoque_atual": 5000, "estoque_minimo": 1000,
    }
    r = session.put(f"{API}/insumos/{iid}", json=payload)
    assert r.status_code == 200
    d = r.json()
    assert abs(d["custo_por_unidade_uso"] - 0.025) < 1e-4


# ---- Fichas: sub-receita + ficha usando sub ----
def test_create_sub_receita(session, created):
    payload = {
        "nome": "TEST_Molho_Base",
        "categoria": "Sub-receita",
        "eh_sub_receita": True,
        "rendimento_bruto": 1000.0,
        "rendimento_liquido": 900.0,
        "unidade_rendimento": "g",
        "porcoes": 1,
        "ingredientes": [
            {"tipo": "insumo", "ref_id": created["insumos"][0], "nome": "", "quantidade": 200, "unidade": "g", "custo_unitario": 0},
            {"tipo": "insumo", "ref_id": created["insumos"][1], "nome": "", "quantidade": 100, "unidade": "g", "custo_unitario": 0},
        ],
    }
    r = session.post(f"{API}/fichas", json=payload)
    assert r.status_code == 200, r.text
    d = r.json()
    # tomate updated to 0.025/g * 200 = 5.0; cebola 0.005/g (5/0.9/1000 ~ 0.005556) * 100 = 0.5556
    expected = 0.025 * 200 + (5.0 / 0.9 / 1000) * 100
    assert abs(d["custo_total"] - round(expected, 4)) < 0.01
    created["fichas"].append(d["id"])
    created["sub_id"] = d["id"]


def test_create_ficha_using_sub(session, created):
    payload = {
        "nome": "TEST_Prato_Principal",
        "categoria": "Prato",
        "eh_sub_receita": False,
        "rendimento_bruto": 1.0, "rendimento_liquido": 1.0,
        "unidade_rendimento": "porcao", "porcoes": 4,
        "impostos_pct": 6.0, "cartao_pct": 3.5, "delivery_pct": 0,
        "outras_taxas_pct": 0, "lucro_desejado_pct": 30.0,
        "ingredientes": [
            {"tipo": "ficha", "ref_id": created["sub_id"], "nome": "", "quantidade": 300, "unidade": "g", "custo_unitario": 0},
            {"tipo": "insumo", "ref_id": created["insumos"][0], "nome": "", "quantidade": 100, "unidade": "g", "custo_unitario": 0},
        ],
    }
    r = session.post(f"{API}/fichas", json=payload)
    assert r.status_code == 200, r.text
    d = r.json()
    # custo_total should be > 0 and preco_venda computed via markup divisor
    assert d["custo_total"] > 0
    assert d["preco_venda"] > d["custo_por_porcao"]
    # markup divisor = 1 - 0.395 = 0.605; preco = custo/0.605
    expected_preco = d["custo_por_porcao"] / 0.605
    assert abs(d["preco_venda"] - round(expected_preco, 2)) < 0.05
    created["fichas"].append(d["id"])
    created["ficha_main_id"] = d["id"]


def test_propagation_on_insumo_update(session, created):
    """When insumo price changes, fichas using it must recalc."""
    # capture current
    fid = created["ficha_main_id"]
    r0 = session.get(f"{API}/fichas/{fid}")
    custo_before = r0.json()["custo_total"]

    iid = created["insumos"][0]
    payload = {
        "nome": "TEST_Tomate", "unidade_compra": "kg", "unidade_uso": "g",
        "fator_conversao": 1000.0, "peso_bruto": 1.0, "peso_liquido": 0.8,
        "preco": 40.0,  # double again
        "estoque_atual": 5000, "estoque_minimo": 1000,
    }
    r = session.put(f"{API}/insumos/{iid}", json=payload)
    assert r.status_code == 200

    r1 = session.get(f"{API}/fichas/{fid}")
    custo_after = r1.json()["custo_total"]
    assert custo_after > custo_before, f"Cost should propagate; before={custo_before} after={custo_after}"


# ---- Vendas ----
def test_create_venda(session, created):
    payload = {"ficha_id": created["ficha_main_id"], "quantidade": 3}
    r = session.post(f"{API}/vendas", json=payload)
    assert r.status_code == 200, r.text
    d = r.json()
    assert d["quantidade"] == 3
    assert d["preco_unitario"] > 0
    assert abs(d["total"] - round(d["preco_unitario"] * 3, 2)) < 0.01
    created["vendas"].append(d["id"])


