"""MISE MANAGER backend API tests"""
import os
import pytest
import requests
from datetime import datetime, timezone

BASE_URL = os.environ.get("REACT_APP_BACKEND_URL", "https://mise-manager-2.preview.emergentagent.com").rstrip("/")
API = f"{BASE_URL}/api"


@pytest.fixture(scope="module")
def session():
    s = requests.Session()
    s.headers.update({"Content-Type": "application/json"})
    return s


@pytest.fixture(scope="module")
def created():
    return {"insumos": [], "fichas": [], "vendas": [], "perdas": [], "cmv": []}


# ---- Health ----
def test_root(session):
    r = session.get(f"{API}/")
    assert r.status_code == 200
    assert r.json().get("status") == "ok"


# ---- Insumos: create + FC calc ----
def test_create_insumo_calc_fc(session, created):
    payload = {
        "nome": "TEST_Tomate",
        "categoria": "Hortifruti",
        "unidade_compra": "kg",
        "unidade_uso": "g",
        "fator_conversao": 1000.0,
        "peso_bruto": 1.0,
        "peso_liquido": 0.8,
        "preco": 10.0,
        "estoque_atual": 5000,
        "estoque_minimo": 1000,
    }
    r = session.post(f"{API}/insumos", json=payload)
    assert r.status_code == 200, r.text
    d = r.json()
    assert d["nome"] == "TEST_Tomate"
    assert abs(d["fator_correcao"] - 1.25) < 0.001  # 1.0/0.8
    # custo_por_unidade_uso = (10/0.8)/1000 = 0.0125
    assert abs(d["custo_por_unidade_uso"] - 0.0125) < 1e-4
    created["insumos"].append(d["id"])


