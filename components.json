# ---- Cleanup ----
def test_zz_cleanup(session, created):
    for vid in created["vendas"]:
        session.delete(f"{API}/vendas/{vid}")
    for pid in created["perdas"]:
        session.delete(f"{API}/perdas/{pid}")
    for cid in created["cmv"]:
        session.delete(f"{API}/cmv/{cid}")
    for fid in created["fichas"]:
        session.delete(f"{API}/fichas/{fid}")
    for iid in created["insumos"]:
        session.delete(f"{API}/insumos/{iid}")
