# ---- CMV ----
def test_create_cmv(session, created):
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    payload = {
        "periodo": today[:7],
        "data_inicio": "2020-01-01",
        "data_fim": today,
        "estoque_inicial": 1000.0,
        "compras": 500.0,
        "estoque_final": 800.0,
        "observacoes": "TEST"
    }
    r = session.post(f"{API}/cmv", json=payload)
    assert r.status_code == 200, r.text
    d = r.json()
    assert d["cmv_real"] == 700.0
    assert d["vendas_total"] > 0  # vendas exist within range
    created["cmv"].append(d["id"])


# ---- Dashboard ----
def test_dashboard_kpis(session):
    r = session.get(f"{API}/dashboard/kpis")
    assert r.status_code == 200
    d = r.json()
    for key in ["total_insumos", "total_fichas", "receita_total", "lucro_bruto", "ticket_medio", "qtd_vendas", "perdas_total"]:
        assert key in d
    assert d["receita_total"] > 0
    assert d["qtd_vendas"] >= 8


