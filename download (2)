# ============ HELPERS ============

def calc_insumo(i: dict) -> dict:
    """Calcula FC e custo por unidade de uso."""
    pb = float(i.get("peso_bruto") or 0)
    pl = float(i.get("peso_liquido") or 0)
    preco = float(i.get("preco") or 0)
    fc_conv = float(i.get("fator_conversao") or 1)
    i["fator_correcao"] = round(pb / pl, 4) if pl > 0 else 1.0
    if pl > 0 and fc_conv > 0:
        # custo por 1 unid_compra líquida / fator_conversao
        i["custo_por_unidade_uso"] = round((preco / pl) / fc_conv, 6)
    else:
        i["custo_por_unidade_uso"] = 0.0
    return i


async def get_custo_ingrediente(ing: dict) -> float:
    """Retorna custo total do ingrediente na quantidade informada."""
    qtd = float(ing.get("quantidade") or 0)
    if ing.get("tipo") == "ficha":
        sub = await db.fichas.find_one({"id": ing["ref_id"]}, {"_id": 0})
        if not sub:
            return 0.0
        # custo por unidade do rendimento líquido da sub-receita
        rend = float(sub.get("rendimento_liquido") or 1.0)
        custo_sub = float(sub.get("custo_total") or 0.0)
        custo_por_unid = custo_sub / rend if rend > 0 else 0.0
        return round(custo_por_unid * qtd, 4)
    ins = await db.insumos.find_one({"id": ing["ref_id"]}, {"_id": 0})
    if not ins:
        return 0.0
    custo_unit = float(ins.get("custo_por_unidade_uso") or 0.0)
    return round(custo_unit * qtd, 4)


async def recalc_ficha(f: dict) -> dict:
    total = 0.0
    new_ings = []
    for ing in f.get("ingredientes", []):
        custo = await get_custo_ingrediente(ing)
        # snapshot nome
        if ing.get("tipo") == "ficha":
            doc = await db.fichas.find_one({"id": ing["ref_id"]}, {"_id": 0, "nome": 1})
        else:
            doc = await db.insumos.find_one({"id": ing["ref_id"]}, {"_id": 0, "nome": 1, "unidade_uso": 1})
        if doc:
            ing["nome"] = doc.get("nome", ing.get("nome", ""))
        ing["custo_unitario"] = round(custo / (ing.get("quantidade") or 1), 6) if ing.get("quantidade") else 0.0
        new_ings.append(ing)
        total += custo
    f["ingredientes"] = new_ings
    f["custo_total"] = round(total, 4)
    porcoes = int(f.get("porcoes") or 1)
    f["custo_por_porcao"] = round(total / porcoes, 4) if porcoes > 0 else total
    rb = float(f.get("rendimento_bruto") or 1)
    rl = float(f.get("rendimento_liquido") or 1)
    f["indice_rendimento"] = round(rl / rb, 4) if rb > 0 else 1.0

    # Markup divisor
    imp = float(f.get("impostos_pct") or 0)
    cart = float(f.get("cartao_pct") or 0)
    deliv = float(f.get("delivery_pct") or 0)
    out = float(f.get("outras_taxas_pct") or 0)
    lucro = float(f.get("lucro_desejado_pct") or 0)
    soma_pct = imp + cart + deliv + out + lucro
    markup_div = 1 - (soma_pct / 100.0)
    custo_porc = f["custo_por_porcao"]
    if markup_div > 0:
        preco = custo_porc / markup_div
    else:
        preco = custo_porc
    f["preco_venda"] = round(preco, 2)
    # margem de contribuição (preço - custo - taxas variáveis)
    taxas_var = preco * ((imp + cart + deliv + out) / 100.0)
    mc_rs = preco - custo_porc - taxas_var
    f["margem_contribuicao_rs"] = round(mc_rs, 2)
    f["margem_contribuicao_pct"] = round((mc_rs / preco * 100), 2) if preco > 0 else 0.0
    return f


async def propagate_ficha_updates(insumo_id: str | None = None, ficha_id: str | None = None):
    """Recalcula fichas que usem esse insumo ou sub-ficha."""
    query = {}
    if insumo_id:
        query = {"ingredientes.ref_id": insumo_id, "ingredientes.tipo": "insumo"}
    elif ficha_id:
        query = {"ingredientes.ref_id": ficha_id, "ingredientes.tipo": "ficha"}
    else:
        return
    fichas = await db.fichas.find(query, {"_id": 0}).to_list(500)
    for f in fichas:
        f = await recalc_ficha(f)
        f["updated_at"] = now_iso()
        await db.fichas.update_one({"id": f["id"]}, {"$set": f})
        # cascade: se esta ficha é sub-receita, repropagar
        if f.get("eh_sub_receita"):
            await propagate_ficha_updates(ficha_id=f["id"])


