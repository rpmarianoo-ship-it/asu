@api_router.get("/insumos", response_model=List[Insumo])
async def list_insumos():
    items = await db.insumos.find({}, {"_id": 0}).sort("nome", 1).to_list(2000)
    return items


@api_router.post("/insumos", response_model=Insumo)
async def create_insumo(data: InsumoCreate):
    obj = Insumo(**data.model_dump()).model_dump()
    obj = calc_insumo(obj)
    await db.insumos.insert_one(obj.copy())
    return obj


@api_router.put("/insumos/{insumo_id}", response_model=Insumo)
async def update_insumo(insumo_id: str, data: InsumoCreate):
    existing = await db.insumos.find_one({"id": insumo_id}, {"_id": 0})
    if not existing:
        raise HTTPException(404, "Insumo não encontrado")
    existing.update(data.model_dump())
    existing["updated_at"] = now_iso()
    existing = calc_insumo(existing)
    await db.insumos.update_one({"id": insumo_id}, {"$set": existing})
    await propagate_ficha_updates(insumo_id=insumo_id)
    return existing


@api_router.delete("/insumos/{insumo_id}")
async def delete_insumo(insumo_id: str):
    r = await db.insumos.delete_one({"id": insumo_id})
    if r.deleted_count == 0:
        raise HTTPException(404, "Insumo não encontrado")
    return {"ok": True}


