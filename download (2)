@api_router.get("/dashboard/kpis")
async def dashboard_kpis():
    insumos = await db.insumos.find({}, {"_id": 0}).to_list(2000)
    fichas = await db.fichas.find({}, {"_id": 0}).to_list(2000)
    vendas = await db.vendas.find({}, {"_id": 0}).to_list(5000)
    perdas = await db.perdas.find({}, {"_id": 0}).to_list(5000)

    total_insumos = len(insumos)
    alertas_estoque = sum(1 for i in insumos if float(i.get("estoque_atual") or 0) <= float(i.get("estoque_minimo") or 0) and float(i.get("estoque_minimo") or 0) > 0)
    total_fichas = sum(1 for f in fichas if not f.get("eh_sub_receita"))
    total_sub_receitas = sum(1 for f in fichas if f.get("eh_sub_receita"))
    receita_total = sum(float(v.get("total") or 0) for v in vendas)
    custo_total_vendas = sum(float(v.get("custo_unitario") or 0) * int(v.get("quantidade") or 0) for v in vendas)
    lucro_bruto = receita_total - custo_total_vendas
    qtd_vendas = sum(int(v.get("quantidade") or 0) for v in vendas)
    ticket_medio = (receita_total / len(vendas)) if vendas else 0.0
    margem_bruta_pct = (lucro_bruto / receita_total * 100) if receita_total > 0 else 0.0
    perdas_total = sum(float(p.get("custo_total") or 0) for p in perdas)

    # ponto de equilíbrio simplificado: custos fixos estimados = perdas + 30% receita (placeholder)
    # usamos: soma dos custos variáveis pct médio
    return {
        "total_insumos": total_insumos,
        "alertas_estoque": alertas_estoque,
        "total_fichas": total_fichas,
        "total_sub_receitas": total_sub_receitas,
        "receita_total": round(receita_total, 2),
        "custo_total_vendas": round(custo_total_vendas, 2),
        "lucro_bruto": round(lucro_bruto, 2),
        "ticket_medio": round(ticket_medio, 2),
        "qtd_vendas": qtd_vendas,
        "margem_bruta_pct": round(margem_bruta_pct, 2),
        "perdas_total": round(perdas_total, 2),
    }


@api_router.get("/dashboard/vendas-por-ficha")
async def vendas_por_ficha():
    vendas = await db.vendas.find({}, {"_id": 0}).to_list(10000)
    agg: dict = {}
    for v in vendas:
        fid = v.get("ficha_id")
        if not fid:
            continue
        if fid not in agg:
            agg[fid] = {"ficha_id": fid, "nome": v.get("ficha_nome", ""), "quantidade": 0, "receita": 0.0, "custo": 0.0}
        agg[fid]["quantidade"] += int(v.get("quantidade") or 0)
        agg[fid]["receita"] += float(v.get("total") or 0)
        agg[fid]["custo"] += float(v.get("custo_unitario") or 0) * int(v.get("quantidade") or 0)
    result = list(agg.values())
    for r in result:
        r["lucro"] = round(r["receita"] - r["custo"], 2)
        r["margem_pct"] = round((r["lucro"] / r["receita"] * 100), 2) if r["receita"] > 0 else 0.0
        r["receita"] = round(r["receita"], 2)
        r["custo"] = round(r["custo"], 2)
    result.sort(key=lambda x: x["receita"], reverse=True)
    return result


@api_router.get("/dashboard/bcg")
async def bcg_matrix():
    """Classifica pratos em Estrela/Burro de Carga/Quebra-cabeça/Cão pela popularidade (qtd) vs margem (%)."""
    vendas = await db.vendas.find({}, {"_id": 0}).to_list(10000)
    agg: dict = {}
    for v in vendas:
        fid = v.get("ficha_id")
        if not fid:
            continue
        if fid not in agg:
            agg[fid] = {"ficha_id": fid, "nome": v.get("ficha_nome", ""), "quantidade": 0, "receita": 0.0, "custo": 0.0}
        agg[fid]["quantidade"] += int(v.get("quantidade") or 0)
        agg[fid]["receita"] += float(v.get("total") or 0)
        agg[fid]["custo"] += float(v.get("custo_unitario") or 0) * int(v.get("quantidade") or 0)
    items = list(agg.values())
    if not items:
        return []
    qtd_media = sum(i["quantidade"] for i in items) / len(items)
    for i in items:
        i["lucro"] = i["receita"] - i["custo"]
        i["margem_pct"] = (i["lucro"] / i["receita"] * 100) if i["receita"] > 0 else 0.0
    margem_media = sum(i["margem_pct"] for i in items) / len(items)
    for i in items:
        popular = i["quantidade"] >= qtd_media
        lucrativo = i["margem_pct"] >= margem_media
        if popular and lucrativo:
            i["classe"] = "Estrela"
        elif popular and not lucrativo:
            i["classe"] = "Burro de Carga"
        elif not popular and lucrativo:
            i["classe"] = "Quebra-cabeça"
        else:
            i["classe"] = "Cão"
        i["popularidade"] = i["quantidade"]
        i["rentabilidade"] = round(i["margem_pct"], 2)
        i["receita"] = round(i["receita"], 2)
        i["lucro"] = round(i["lucro"], 2)
    return {"qtd_media": round(qtd_media, 2), "margem_media": round(margem_media, 2), "items": items}


@api_router.get("/dashboard/curva-abc")
async def curva_abc():
    """Curva ABC dos insumos por valor usado (estoque_atual * custo_por_unidade_uso)."""
    insumos = await db.insumos.find({}, {"_id": 0}).to_list(2000)
    items = []
    for i in insumos:
        valor = float(i.get("estoque_atual") or 0) * float(i.get("custo_por_unidade_uso") or 0)
        items.append({"nome": i.get("nome", ""), "valor": round(valor, 2), "estoque": i.get("estoque_atual", 0), "unidade": i.get("unidade_uso", "")})
    items.sort(key=lambda x: x["valor"], reverse=True)
    total = sum(i["valor"] for i in items) or 1
    acc = 0.0
    for i in items:
        acc += i["valor"]
        pct = (acc / total) * 100
        i["acumulado_pct"] = round(pct, 2)
        if pct <= 80:
            i["classe"] = "A"
        elif pct <= 95:
            i["classe"] = "B"
        else:
            i["classe"] = "C"
    return items


