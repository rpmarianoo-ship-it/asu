@api_router.get("/cmv", response_model=List[FechamentoCMV])
async def list_cmv():
    items = await db.cmv.find({}, {"_id": 0}).sort("periodo", -1).to_list(500)
    return items


@api_router.post("/cmv", response_model=FechamentoCMV)
async def create_cmv(data: FechamentoCreate):
    # CMV Real
    cmv_real = data.estoque_inicial + data.compras - data.estoque_final
    # Vendas do período
    vendas = await db.vendas.find({
        "data": {"$gte": data.data_inicio, "$lte": data.data_fim + "T23:59:59"}
    }, {"_id": 0}).to_list(10000)
    vendas_total = sum(float(v.get("total") or 0) for v in vendas)
    cmv_teorico = sum(float(v.get("custo_unitario") or 0) * int(v.get("quantidade") or 0) for v in vendas)
    cmv_real_pct = (cmv_real / vendas_total * 100) if vendas_total > 0 else 0.0
    cmv_teorico_pct = (cmv_teorico / vendas_total * 100) if vendas_total > 0 else 0.0
    desvio = cmv_real - cmv_teorico
    desvio_pct = cmv_real_pct - cmv_teorico_pct

    obj = FechamentoCMV(
        periodo=data.periodo,
        data_inicio=data.data_inicio,
        data_fim=data.data_fim,
        estoque_inicial=data.estoque_inicial,
        compras=data.compras,
        estoque_final=data.estoque_final,
        cmv_real=round(cmv_real, 2),
        vendas_total=round(vendas_total, 2),
        cmv_teorico=round(cmv_teorico, 2),
        cmv_real_pct=round(cmv_real_pct, 2),
        cmv_teorico_pct=round(cmv_teorico_pct, 2),
        desvio=round(desvio, 2),
        desvio_pct=round(desvio_pct, 2),
        observacoes=data.observacoes,
    ).model_dump()
    await db.cmv.insert_one(obj.copy())
    return obj


